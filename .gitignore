# ─── Dependencies ─────────────────────────────────────
node_modules/

# ─── Environment Secrets ──────────────────────────────
# All .env variants are secrets — only .env.example files are committed
.env
.env.*
!.env.example
!.env.*.example

# ─── Logs ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ─── Uploads (user-uploaded files) ────────────────────
uploads/

# ─── Build / Compiled ─────────────────────────────────
dist/
build/
.next/

# ─── Test Coverage ────────────────────────────────────
coverage/

# ─── OS & Editor Artifacts ────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json

# ─── Prisma Generated Client ──────────────────────────
# The generated client is always re-created via `prisma generate`
# node_modules/@prisma/client is excluded above via node_modules/

# ─── Development Debug Scripts ────────────────────────
# These are one-off scripts created during development.
# They are excluded from the Docker image via .dockerignore
# and excluded from the public repository here.
check.js
check2.js
test-db.js
generate_token.js

# ─── Temporary / Generated Outputs ───────────────────
lint_output.txt
swagger.json

# ─── Windows-only Dev Automation ─────────────────────
run_all.ps1

# ─── Misc ─────────────────────────────────────────────
*.swp
*.swo
