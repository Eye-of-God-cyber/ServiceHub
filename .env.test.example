# ─────────────────────────────────────────────────────────────────────────────
# .env.test.example — Test environment template
#
# Copy this file to .env.test and fill in your own values.
# NEVER commit .env.test to Git — it contains real database credentials.
#
# The test environment uses a dedicated `test_schema` within the same database
# so test data is completely isolated from production and development data.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=test

# PostgreSQL connection string pointing to the test_schema
# Use a separate Neon branch, a local PostgreSQL instance, or a CI service container
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require&schema=test_schema"

# JWT secrets for tests — use simple strings, NOT production secrets
JWT_SECRET="test_access_secret_replace_in_ci"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="test_refresh_secret_replace_in_ci"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS — wildcard is acceptable for local test runs
CORS_ALLOWED_ORIGINS="*"

# Rate limiting — set high for tests to avoid throttling during test suites
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=1000

# Logging — suppress all output during tests to keep output clean
LOG_LEVEL=error

# bcrypt — use 1 round in tests for speed (NOT acceptable in production)
BCRYPT_SALT_ROUNDS=1
