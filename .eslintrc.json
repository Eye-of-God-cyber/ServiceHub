{
  "env": {
    "node": true,
    "es2022": true,
    "commonjs": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "commonjs"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "node/no-unsupported-features/es-syntax": "off",
    "node/no-missing-require": "error",
    "node/no-extraneous-require": "error"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "prisma/seed.js"
  ]
}
