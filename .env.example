# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────

# Environment: development | production | test
NODE_ENV=development

# Port the Express server will listen on (must match Dockerfile EXPOSE 3000)
PORT=3000

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────

# Full PostgreSQL connection string used by Prisma
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=<schema>
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/servicehub_db?schema=public

# ─────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────

# Secret key used to sign JWTs — must be a long random string in production
JWT_SECRET=replace_with_a_strong_random_secret_at_least_64_chars

# Lifetime of an access token (e.g. 15m, 1h, 7d)
JWT_EXPIRES_IN=15m

# Secret key used to sign refresh tokens — different from JWT_SECRET
JWT_REFRESH_SECRET=replace_with_a_different_strong_random_secret

# Lifetime of a refresh token
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────

# Comma-separated list of allowed origins (no trailing slashes)
# Example: http://localhost:3000,https://servicehub.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────

# Time window for rate limiting in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# Maximum number of requests per IP within the window
RATE_LIMIT_MAX_REQUESTS=100

# ─────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────

# Minimum log level: error | warn | info | http | debug
LOG_LEVEL=info

# ─────────────────────────────────────────────
# FILE UPLOADS
# ─────────────────────────────────────────────

# Maximum file size in bytes for uploads (default: 5MB = 5242880)
MAX_FILE_SIZE_BYTES=5242880

# Directory for uploaded files (relative to project root)
UPLOAD_DIR=uploads

# ─────────────────────────────────────────────
# BCRYPT
# ─────────────────────────────────────────────

# Salt rounds for bcrypt hashing — higher is more secure but slower (recommended: 12)
BCRYPT_SALT_ROUNDS=12
